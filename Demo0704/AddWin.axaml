<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="460" MaxWidth="610" MaxHeight="460"
        x:Class="Demo0704.AddWin"
        WindowStartupLocation="CenterScreen"
        Title="AddWin"
        x:CompileBindings="False">
  <Border BorderThickness="1" Width="600" Height="450" BorderBrush="Black">
      <Grid ColumnDefinitions="* *" >
          <StackPanel Grid.ColumnSpan="2">
          <TextBlock x:Name="Titles" HorizontalAlignment="Center" Margin="5" FontSize="24"/>
              </StackPanel>
	  <StackPanel VerticalAlignment="Center">
          
		  <StackPanel Orientation="Horizontal" Margin="5" Spacing="5">
			  <TextBox x:Name="Art" Text="{Binding Articul}" Watermark="Введите артикул" Width="140" />
			  <TextBox x:Name="Nam" Text="{Binding Name}" Watermark="Введите название" Width="150" />
          </StackPanel>
          <StackPanel Spacing="5" Margin="5">
          <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="Выбирете в чем измеряется:"/>
                  <ComboBox x:Name="Izmer">    
              <ComboBox.ItemTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding Name}"/>
                              </DataTemplate>
                          </ComboBox.ItemTemplate>
                  </ComboBox>
              </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="Выбирете поставщика:"/>
                  <ComboBox x:Name="Postav">	
                      <ComboBox.ItemTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding Name}"/>
                              </DataTemplate>
                          </ComboBox.ItemTemplate>
                  </ComboBox>
                  </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="Выбирете производителя:"/>
                  <ComboBox x:Name="Maker">
				        <ComboBox.ItemTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding Name}"/>
                              </DataTemplate>
                          </ComboBox.ItemTemplate>
                  </ComboBox>
                  </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="Выбирете категорию:"/>
                  <ComboBox x:Name="Categ">  
                  <ComboBox.ItemTemplate>
                              <DataTemplate>
                                  <TextBlock Text="{Binding Name}"/>
                              </DataTemplate>
                          </ComboBox.ItemTemplate>
                  </ComboBox>
                  </StackPanel>
              </StackPanel>
          <StackPanel Spacing="5" Margin="5">
			  <TextBox 
              Text="{Binding Discription}"
              x:Name="Disp" Watermark="Описание" TextWrapping="Wrap"
              AcceptsReturn="True" Height="60"/>
              <StackPanel Orientation="Horizontal" Spacing="5">
                  <NumericUpDown 
                  Minimum="0,00" ShowButtonSpinner="False"  
                  x:Name="Pric" Text="{Binding Price}" Watermark="Цена" Width="40"/>
                  <NumericUpDown 
                  ShowButtonSpinner="False" Minimum="0" Maximum="100" 
                  Text="{Binding MaxDiscount}"
                  x:Name="MaxDi" Width="115" Watermark="Макс. Скидка"/>
              </StackPanel>
			  <StackPanel Orientation="Horizontal" Spacing="5">
			  
			  <NumericUpDown 
              Text="{Binding DiscountNow}"
              ShowButtonSpinner="False" 
                             Minimum="0" Maximum="100" x:Name="NowDi" Watermark="Скидка сейчас" Width="125"/>
			  <TextBox
              Text="{Binding InSklad}"
              x:Name="HowMach" Watermark="кол-во на складе" Width="140"/>
          </StackPanel>
               <Button x:Name="SelectImageButton" Content="Выбрать изображение" Margin="0 10" Width="180"/>
              </StackPanel>
      </StackPanel>

          <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
              <Image x:Name="ProductImage" Source="{Binding Image}" Width="200" Height="200" Stretch="Uniform"/>
              <TextBlock x:Name="ImagePathText" Text="{Binding Picture}" FontSize="10" TextWrapping="Wrap" Width="200" Margin="0 5"/>
          </StackPanel>

          <Button 
          Name="SaveButton"
          Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0 10"
                  Content="Сохранить"/>

         
          </Grid>
  </Border>
</Window>
