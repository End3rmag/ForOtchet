<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Demo0704.MainWindow"
        Title="Demo0704">
    <Grid RowDefinitions="* * *" ShowGridLines="True">
		<TextBox x:Name="LoginBox" Watermark="Введите логин" VerticalContentAlignment="Center"/>
		<TextBox x:Name="PasswordBox" Grid.Row="1" Watermark="Введите пароль" VerticalContentAlignment="Center"/>
		<Button Grid.Row="2" Content="Авторизоваться" FontSize="30" Click="Button_Click"/>
    </Grid>
</Window>
